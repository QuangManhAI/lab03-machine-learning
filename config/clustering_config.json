{
  "random_seed": 42,
  "raw_data_glob": "data/raw/*.csv",
  "feature_sets": {
    "behavior_numeric": ["age", "annual_income", "spending_score"],
    "behavior_plus_gender": ["age", "annual_income", "spending_score", "gender"],
    "income_spending_only": ["annual_income", "spending_score"],
    "age_spending_only": ["age", "spending_score"]
  },
  "scalers": ["standard", "minmax", "robust"],
  "kmeans_k_range": [2, 10],
  "gmm_k_range": [2, 10],
  "selection": {
    "min_clusters": 3,
    "max_clusters": 7,
    "max_noise_rate": 0.35
  }
}
